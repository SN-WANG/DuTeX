% =============================================================================
% 6. FOOTER & UTILITY UI
% =============================================================================

\defbeamertemplate{footline}{wsnextheme}{
    \ifnum \the\value{page}>1
    \ifnum\insertframenumber<\inserttotalframenumber
    \leavevmode\hbox{%
        \begin{beamercolorbox}[wd=.2\paperwidth,ht=2.25ex,dp=1ex,center]{author in head/foot}
            \usebeamerfont{author in head/foot}\insertshortauthor
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.6\paperwidth,ht=2.25ex,dp=1ex,center]{title in head/foot}
            \usebeamerfont{title in head/foot}\insertshorttitle
        \end{beamercolorbox}%
        \begin{beamercolorbox}[wd=.2\paperwidth,ht=2.25ex,dp=1ex,center]{author in head/foot}
            \insertframenumber{} / \inserttotalframenumber
    \end{beamercolorbox}}\fi\fi
}
% \setbeamertemplate{footline}[wsnextheme]
\setbeamertemplate{footline}{} % Default to empty

% Usage: \wsnfooter{Text content}
\RequirePackage[absolute,overlay]{textpos}
\tikzfading[name=footer fade, left color=transparent!0, right color=transparent!40]
\newcommand{\wsnfooter}[1]{%
    \begin{textblock*}{\paperwidth}(0cm, \paperheight-1cm)
        \begin{tikzpicture}
            \fill[wsnPrimary, path fading=footer fade] (0, 0) rectangle (\paperwidth, 1cm);
            \node[text width=0.9\paperwidth, align=center, text=white, alerted text/.style={color=white}] 
                 at (0.5\paperwidth, 0.5cm) {#1};
        \end{tikzpicture}
    \end{textblock*}%
}

\endinput